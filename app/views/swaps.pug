extends layout

block content
  .container
    h1 Swap History

    if !swaps || swaps.length === 0
      p No swap requests yet.

    else
      table
        thead
          tr
            th Item
            th Requested By
            th Status
            th Actions

        tbody
          each swap in swaps
            tr
              td= swap.item_title
              td= swap.requester_name
              td= swap.status
              td
                if swap.status === "pending"
                  form(action=`/swaps/accept/${swap.id}` method="POST")
                    button.btn(type="submit") Accept

                  form(action=`/swaps/decline/${swap.id}` method="POST")
                    button.btn(type="submit") Decline
                else
                  span No action required